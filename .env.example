# Google Sheets API
# URL do Google Apps Script que serve como backend
NEXT_PUBLIC_GOOGLE_SHEET_API_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# WhatsApp Integration
# Número do WhatsApp para receber pedidos (formato: código do país + DDD + número)
# Exemplo: 5541991480096 (Brasil +55, Curitiba 41, número 991480096)
NEXT_PUBLIC_WHATSAPP_PHONE=5541991480096

# Supabase (Cache Ultra-Rápido)
# Crie um projeto em https://supabase.com e preencha abaixo
# O frontend tentará Supabase primeiro, com fallback para Google Apps Script
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
